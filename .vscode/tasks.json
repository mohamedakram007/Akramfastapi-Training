{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: install packages",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: run FastAPI",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: install packages",
      "type": "shell",
      "command": "npm.cmd install",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: run Next.js",
      "type": "shell",
      "command": "npm.cmd run dev",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
